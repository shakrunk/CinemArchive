# Copy this file to .env.local and fill in your Supabase project's public values.
# Find these in the Supabase dashboard: Settings > API.
VITE_SUPABASE_URL=https://<your-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# TMDB/OMDb API keys are NOT set here - they live server-side as secrets on the
# media-proxy Edge Function (supabase secrets set TMDB_API_KEY=... / OMDB_API_KEY=...),
# so they never reach the browser.
