# Copy the two lines below into your real android/local.properties (already gitignored,
# alongside sdk.dir) and fill in your Supabase project's public values. Find these in the
# Supabase dashboard: Settings > API Keys — the "Publishable key" (sb_publishable_...),
# the current name for what the web app's .env.example still calls VITE_SUPABASE_ANON_KEY
# (Supabase renamed anon/service_role keys to publishable/secret; publishable is a drop-in
# replacement for the apikey header, no behavior difference).
SUPABASE_URL=https://<your-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=<your-publishable-key>
